app_identifier(ENV.fetch("FASTLANE_APP_IDENTIFIER", "com.kin-yee.spezhe"))

apple_account = ENV["FASTLANE_APPLE_ID"]
apple_id(apple_account) unless apple_account.to_s.empty?

app_store_team_id = ENV["FASTLANE_ITC_TEAM_ID"]
itc_team_id(app_store_team_id) unless app_store_team_id.to_s.empty?

developer_portal_team_id = ENV["FASTLANE_TEAM_ID"]
team_id(developer_portal_team_id) unless developer_portal_team_id.to_s.empty?

